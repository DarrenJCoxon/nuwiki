{
  "name": "@nusoft/nuwiki",
  "version": "0.1.3",
  "description": "Private NuWiki — the compiled knowledge engine of NuOS. Maintains a living, cited, role-aware substrate of institutional understanding (LLM-compiled from authoritative sources) and publishes every article into NuVector's four-layer index.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./pack": {
      "types": "./dist/src/pack.d.ts",
      "default": "./dist/src/pack.js"
    },
    "./agent-tools": {
      "types": "./dist/src/agent-tools.d.ts",
      "default": "./dist/src/agent-tools.js"
    },
    "./export": {
      "types": "./dist/src/export.d.ts",
      "default": "./dist/src/export.js"
    },
    "./obsidian": {
      "types": "./dist/src/obsidian.d.ts",
      "default": "./dist/src/obsidian.js"
    },
    "./postgres": {
      "types": "./dist/src/postgres.d.ts",
      "default": "./dist/src/postgres.js"
    },
    "./storage": {
      "types": "./dist/src/storage.d.ts",
      "default": "./dist/src/storage.js"
    },
    "./nuvector": {
      "types": "./dist/src/nuvector-adapter.d.ts",
      "default": "./dist/src/nuvector-adapter.js"
    },
    "./llm": {
      "types": "./dist/src/llm.d.ts",
      "default": "./dist/src/llm.js"
    },
    "./database-source": {
      "types": "./dist/src/database-source.d.ts",
      "default": "./dist/src/database-source.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "npm run build && node --test tests/*.test.js",
    "prepublishOnly": "npm run build",
    "verify:nuwiki": "node scripts/verify-nuwiki-package.cjs"
  },
  "dependencies": {
    "@nusoft/nuvector": "0.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "nuwiki",
    "nusoft",
    "knowledge",
    "compiled-knowledge",
    "llm-maintained",
    "wiki",
    "nuos"
  ],
  "author": "Kompass Education (UK) Limited <darren@coxon.ai>",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
